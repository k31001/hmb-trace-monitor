mock/build/
mock/work/
mock/images/
mock/linux/
*.qcow2
*.img

# --- local trace data ---
dumps/
traces/
*.bin
!docs/test-vectors/*.bin

# --- editor / OS ---
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

