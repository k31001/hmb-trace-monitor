*.mod.c
*.mod.o
.*.cmd
modules.order
Module.symvers
*.symvers
.tmp_versions/
*.dwo
*.d

# --- daemon binaries ---
daemon/build/
daemon/hmb-trace-daemon
daemon/*.a

# --- Python / analyzer ---
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.uv/
uv.lock
.uv-cache/
dist/
build/
*.egg-info/
.mypy_cache/
.ruff_cache/
